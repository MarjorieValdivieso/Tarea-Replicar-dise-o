<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mitienda.AdminController">

   <left>
      <VBox spacing="15" styleClass="sidebar">
         <Label text="MiTienda" styleClass="title" />
         <Button text="Inicio" />
         <Button text="Productos" />
         <Button text="Categorías" />
         <Button text="Clientes" />
         <Button text="Ventas" />
      </VBox>
   </left>

   <center>
      <VBox spacing="20" styleClass="main-content">

         <Label text="Productos" styleClass="title-page" />

         <VBox styleClass="card-panel" spacing="15">
            <GridPane hgap="15" vgap="15">
               <columnConstraints>
                  <ColumnConstraints minWidth="70" prefWidth="80" />
                  <ColumnConstraints hgrow="ALWAYS" />
                  <ColumnConstraints minWidth="70" prefWidth="80" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>

               <Label text="Código" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
               <TextField fx:id="txtCodigo" promptText="Ej: P001" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

               <Label text="Nombre" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
               <TextField fx:id="txtNombre" promptText="Ingrese el nombre" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

               <Label text="Categoría" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
               <ComboBox fx:id="cmbCategoria" promptText="Seleccione una categoría" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

               <Label text="Precio" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
               <TextField fx:id="txtPrecio" promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

               <Label text="Stock" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
               <TextField fx:id="txtStock" promptText="0" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

               <Label text="Estado" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
               <ComboBox fx:id="cmbEstado" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
            </GridPane>

            <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
               <Button text="+ Nuevo" onAction="#nuevo" styleClass="btn-crud, btn-nuevo"/>
               <Button text="Guardar" onAction="#guardar" styleClass="btn-crud, btn-guardar"/>
               <Button text="Actualizar" onAction="#actualizar" styleClass="btn-crud, btn-actualizar"/>
               <Button text="Eliminar" onAction="#eliminar" styleClass="btn-crud, btn-eliminar"/>
               <Button text="Limpiar" onAction="#limpiar" styleClass="btn-crud, btn-limpiar"/>
            </HBox>
         </VBox>

         <TableView fx:id="tablaProductos" onMouseClicked="#seleccionar" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colCodigo" text="Código" prefWidth="100"/>
               <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
               <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120"/>
               <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
               <TableColumn fx:id="colStock" text="Stock" prefWidth="100"/>
               <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
         </TableView>

      </VBox>
   </center>

</BorderPane>